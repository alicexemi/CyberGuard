  <!-- Скрипты -->
  <script>
    // ===== ДОСТИЖЕНИЯ: КОНФИГУРАЦИЯ =====
    const ACHIEVEMENTS = {
      first_step: { id: 'first_step', icon: '🌱', title: 'Первый шаг', desc: 'Пройдите первый тест', unlocked: false },
      detective: { id: 'detective', icon: '🔍', title: 'Детектив', desc: 'Распознайте 3 фишинговых письма', unlocked: false },
      protector: { id: 'protector', icon: '🛡️', title: 'Защитник', desc: 'Получите 80%+ в тесте', unlocked: false },
      ai_master: { id: 'ai_master', icon: '🤖', title: 'AI-Эксперт', desc: 'Правильно определите 5 AI-видео', unlocked: false },
      streak_3: { id: 'streak_3', icon: '🔥', title: 'Серия 3', desc: 'Заходите 3 дня подряд', unlocked: false },
      perfectionist: { id: 'perfectionist', icon: '⭐', title: 'Перфекционист', desc: '100% в любом тесте', unlocked: false }
    };

    // ===== СОСТОЯНИЕ ПОЛЬЗОВАТЕЛЯ =====
    let userState = {
      name: 'Гость',
      xp: 0,
      level: 'Новичок',
      testsPassed: 0,
      achievements: {},
      lastLogin: null,
      streak: 0,
      phishCorrect: 0,
      videoCorrect: 0
    };

    // ===== ЗАГРУЗКА/СОХРАНЕНИЕ ДАННЫХ =====
    function loadUserData() {
      const saved = localStorage.getItem('cyberguard_user');
      if (saved) {
        userState = { ...userState, ...JSON.parse(saved) };
        // Проверка серии дней
        checkStreak();
      }
      updateProfileUI();
      renderAchievements();
    }

    function saveUserData() {
      localStorage.setItem('cyberguard_user', JSON.stringify(userState));
    }

    function checkStreak() {
      const today = new Date().toDateString();
      const last = userState.lastLogin;
      if (last) {
        const lastDate = new Date(last);
        const diffDays = Math.floor((new Date(today) - lastDate) / (1000*60*60*24));
        if (diffDays === 1) {
          userState.streak++;
          if (userState.streak >= 3 && !userState.achievements['streak_3']) {
            unlockAchievement('streak_3');
          }
        } else if (diffDays > 1) {
          userState.streak = 1;
        }
      } else {
        userState.streak = 1;
      }
      userState.lastLogin = today;
      saveUserData();
    }

    // ===== УВЕДОМЛЕНИЕ О ДОСТИЖЕНИИ =====
    function showAchievementNotification(achievement) {
      const notif = document.getElementById('achievementNotification');
      document.getElementById('achievementTitle').textContent = `🏆 ${achievement.title}`;
      document.getElementById('achievementDesc').textContent = achievement.desc;
      
      notif.classList.remove('hide');
      notif.classList.add('show');
      
      // Конфетти-эффект
      createConfetti();
      
      // Автоскрытие через 5 сек
      setTimeout(() => hideAchievementNotification(), 5000);
    }

    function hideAchievementNotification() {
      const notif = document.getElementById('achievementNotification');
      notif.classList.remove('show');
      notif.classList.add('hide');
    }

    function createConfetti() {
      const colors = ['#fbbf24', '#6366f1', '#10b981', '#ef4444', '#f59e0b'];
      for (let i = 0; i < 30; i++) {
        const confetti = document.createElement('div');
        confetti.className = 'confetti';
        confetti.style.left = Math.random() * 100 + 'vw';
        confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
        confetti.style.animationDuration = (2 + Math.random() * 2) + 's';
        confetti.style.animationDelay = Math.random() * 0.5 + 's';
        document.body.appendChild(confetti);
        setTimeout(() => confetti.remove(), 4000);
      }
    }

    // ===== РАЗБЛОКИРОВКА ДОСТИЖЕНИЯ =====
    function unlockAchievement(achievementId) {
      if (userState.achievements[achievementId]) return;
      
      const achievement = ACHIEVEMENTS[achievementId];
      if (!achievement) return;
      
      userState.achievements[achievementId] = true;
      userState.xp += 100;
      updateLevel();
      saveUserData();
      
      showAchievementNotification(achievement);
      updateProfileUI();
      renderAchievements();
    }

    function updateLevel() {
      const xp = userState.xp;
      if (xp >= 2000) userState.level = 'Легенда';
      else if (xp >= 1000) userState.level = 'Эксперт';
      else if (xp >= 500) userState.level = 'Продвинутый';
      else if (xp >= 100) userState.level = 'Средний';
      else userState.level = 'Новичок';
    }

    // ===== ОТРИСОВКА ДОСТИЖЕНИЙ В ПРОФИЛЕ =====
    function renderAchievements() {
      const container = document.getElementById('achievementsList');
      container.innerHTML = '';
      
      Object.values(ACHIEVEMENTS).forEach(ach => {
        const div = document.createElement('div');
        div.className = `achievement ${userState.achievements[ach.id] ? 'unlocked' : 'locked'}`;
        div.innerHTML = `<span class="icon">${ach.icon}</span> ${ach.title}`;
        div.title = ach.desc + (userState.achievements[ach.id] ? ' ✅' : ' 🔒');
        container.appendChild(div);
      });
      
      const unlocked = Object.values(userState.achievements).filter(v => v).length;
      document.getElementById('unlockedCount').textContent = unlocked;
      document.getElementById('achievementsCount').textContent = unlocked;
    }

    // ===== ОБНОВЛЕНИЕ ПРОФИЛЯ =====
    function updateProfileUI() {
      document.getElementById('userName').textContent = userState.name;
      document.getElementById('userXP').textContent = userState.xp;
      document.getElementById('userLevel').textContent = userState.level;
      document.getElementById('xpProgress').style.width = Math.min((userState.xp / 1000) * 100, 100) + '%';
      document.getElementById('testsPassed').textContent = userState.testsPassed;
      document.getElementById('streakDays').textContent = userState.streak;
      
      const avg = userState.testsPassed > 0 ? Math.round(85) : 0; // заглушка
      document.getElementById('avgScore').textContent = avg + '%';
    }

    // ===== ПЕРЕДАЧА ИМЕНИ ИЗ СЕРТИФИКАТА В ПРОФИЛЬ =====
    function updateUserNameFromCert() {
      const name = document.getElementById('certName').value.trim();
      const surname = document.getElementById('certSurname').value.trim();
      if (name && surname) {
        userState.name = `${name} ${surname}`;
        document.getElementById('userName').textContent = userState.name;
        document.getElementById('userAvatar').textContent = name[0]?.toUpperCase() || 'Г';
        saveUserData();
      }
    }

    // ===== ПРОВЕРКА ДОСТИЖЕНИЙ ПОСЛЕ ТЕСТА =====
    function checkAchievementsAfterTest(score, correctCount) {
      // Первый тест
      if (!userState.achievements['first_step'] && userState.testsPassed === 0) {
        unlockAchievement('first_step');
      }
      
      // 80%+
      if (score >= 80 && !userState.achievements['protector']) {
        unlockAchievement('protector');
      }
      
      // 100%
      if (score === 100 && !userState.achievements['perfectionist']) {
        unlockAchievement('perfectionist');
      }
      
      userState.testsPassed++;
      saveUserData();
      updateProfileUI();
    }

    // ===== ИНИЦИАЛИЗАЦИЯ =====
    document.addEventListener('DOMContentLoaded', () => {
      loadUserData();
      
      // Переключение темы
      const themeToggle = document.getElementById('themeToggle');
      const html = document.documentElement;
      const savedTheme = localStorage.getItem('theme') || 'light';
      html.setAttribute('data-theme', savedTheme);
      themeToggle.textContent = savedTheme === 'dark' ? '☀️' : '🌙';
      
      themeToggle.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        themeToggle.textContent = next === 'dark' ? '☀️' : '🌙';
      });
      
      // Закрытие уведомления о достижении
      document.getElementById('achievementClose').addEventListener('click', hideAchievementNotification);
      
      // Генерация сертификата
      document.getElementById('generateCertBtn').addEventListener('click', () => {
        updateUserNameFromCert();
        const name = document.getElementById('certName').value || 'Иван';
        const surname = document.getElementById('certSurname').value || 'Иванов';
        document.getElementById('certFullName').textContent = `${name} ${surname}`;
        
        const certPreview = document.getElementById('certPreview');
        certPreview.style.opacity = '0.5';
        setTimeout(() => { certPreview.style.opacity = '1'; }, 300);
        
        // Достижение за сертификат
        if (!userState.achievements['first_step']) {
          unlockAchievement('first_step');
        }
      });
      
      // Кнопка "Пройти тест заново" - симуляция завершения теста
      document.getElementById('retakeBtn')?.addEventListener('click', () => {
        // Симуляция: 90% результат
        checkAchievementsAfterTest(90, 12);
      });
      
      // Симуляция фишинг-достижения
      document.getElementById('phishingBtn')?.addEventListener('click', () => {
        userState.phishCorrect++;
        if (userState.phishCorrect >= 3 && !userState.achievements['detective']) {
          unlockAchievement('detective');
        }
        saveUserData();
      });
      
      // Симуляция AI-видео достижения
      document.getElementById('aiBtn')?.addEventListener('click', () => {
        userState.videoCorrect++;
        if (userState.videoCorrect >= 5 && !userState.achievements['ai_master']) {
          unlockAchievement('ai_master');
        }
        saveUserData();
      });
      
      // Очистка данных
      document.getElementById('clearDataBtn')?.addEventListener('click', () => {
        if (confirm('Удалить все данные профиля?')) {
          localStorage.removeItem('cyberguard_user');
          location.reload();
        }
      });
      
      // Плавная прокрутка
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
          e.preventDefault();
          const target = document.querySelector(this.getAttribute('href'));
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    });

    // ===== СКАНЕР ФАЙЛОВ =====
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');
    const selectFileBtn = document.getElementById('selectFileBtn');
    
    if (selectFileBtn) {
      selectFileBtn.addEventListener('click', () => fileInput.click());
      dropZone?.addEventListener('click', () => fileInput.click());
      
      dropZone?.addEventListener('dragover', (e) => {
        e.preventDefault();
        dropZone.classList.add('dragover');
      });
      
      dropZone?.addEventListener('dragleave', () => {
        dropZone.classList.remove('dragover');
      });
      
      dropZone?.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.classList.remove('dragover');
        const files = e.dataTransfer.files;
        if (files.length) handleFile(files[0]);
      });
      
      fileInput.addEventListener('change', (e) => {
        if (e.target.files.length) handleFile(e.target.files[0]);
      });
    }
    
    function handleFile(file) {
      document.getElementById('fileName').textContent = `📄 ${file.name}`;
      document.getElementById('fileSize').textContent = formatFileSize(file.size);
      document.getElementById('fileInfo').classList.add('show');
      document.getElementById('scanStatus').textContent = 'Анализ файла...';
      document.getElementById('scanResult').className = 'scan-result';
      document.getElementById('scanResult').textContent = '⏳ Проверка...';
      
      setTimeout(() => {
        document.getElementById('scanStatus').textContent = 'Завершено';
        document.getElementById('scanResult').classList.add('safe');
        document.getElementById('scanResult').textContent = '✅ Безопасно';
      }, 2000);
    }
    
    function formatFileSize(bytes) {
      if (bytes === 0) return '0 Bytes';
      const k = 1024;
      const sizes = ['Bytes', 'KB', 'MB', 'GB'];
      const i = Math.floor(Math.log(bytes) / Math.log(k));
      return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
    }

    // ===== ПРОВЕРКА УТЕЧЕК =====
    document.getElementById('checkBreachBtn')?.addEventListener('click', () => {
      const email = document.getElementById('emailInput').value.trim();
      const result = document.getElementById('breachResult');
      
      if (!email || !email.includes('@')) {
        result.textContent = '⚠️ Пожалуйста, введите корректный email';
        result.className = 'breach-result show compromised';
        return;
      }
      
      result.className = 'breach-result show';
      result.textContent = '🔄 Проверка...';
      
      setTimeout(() => {
        const isSafe = Math.random() > 0.3;
        if (isSafe) {
          result.className = 'breach-result show safe';
          result.textContent = '✅ Ваш email не найден в известных утечках (демо-режим)';
        } else {
          result.className = 'breach-result show compromised';
          result.textContent = '⚠️ Ваш email найден в 2 утечках. Рекомендуется сменить пароль!';
        }
      }, 1500);
    });
  </script>
</body>
</html>
